{
  "manifest_version": 2,
  "name": "Startmine Miro CORS Helper",
  "version": "2.3",
  "description": "Bypasses CORS dynamically with credentials and programmatic fetching for Miro API image resources.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "https://miro.com/*",
    "https://*.miro.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
